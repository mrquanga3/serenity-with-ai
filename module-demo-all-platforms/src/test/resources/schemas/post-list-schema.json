{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "title", "body", "userId"],
    "properties": {
      "id":     { "type": "integer" },
      "title":  { "type": "string"  },
      "body":   { "type": "string"  },
      "userId": { "type": "integer" }
    }
  },
  "minItems": 1
}
